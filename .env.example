# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Drizzle
DATABASE_URL="postgresql://user:password@localhost:5432/exammanager"

# Next Auth
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Portfolio showcase: leave unset/true to block sign-in. Set both to false to enable auth locally.
AUTH_DISABLED="true"
NEXT_PUBLIC_AUTH_DISABLED="true"

# Next Auth Google Provider
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Next Auth Github Provider
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Resend Api key
RESEND_API_KEY="re_your_resend_api_key"

# Uploadthing keys
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_ID="your-uploadthing-id"

# Subscriptions (Stripe)
STRIPE_API_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRO_MONTHLY_PLAN_ID="price_xxx"
STRIPE_ENTERPRISE_MONTHLY_PLAN_ID="price_xxx"
